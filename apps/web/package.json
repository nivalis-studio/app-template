		"@prisma/adapter-neon": "catalog:",
		"@prisma/client": "catalog:",
		"@sentry/nextjs": "catalog:",
		"@vercel/analytics": "catalog:",
		"@vercel/config": "catalog:",
		"@vercel/queue": "catalog:",
		"ai": "catalog:",
		"babel-plugin-react-compiler": "catalog:",
		"better-auth": "catalog:",
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"dotenv": "catalog:",
		"effect": "catalog:",
		"lucide-react": "catalog:",
		"next": "catalog:",
		"postcss": "catalog:",
		"prisma": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"server-only": "catalog:",
