{
	"name": "@nivalis/app-template-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": "24.x",
		"pnpm": "10.x"
	},
	"scripts": {
		"dev": "turbo dev --filter=@nivalis/web",
		"build": "turbo build",
		"start": "pnpm --filter=@nivalis/web start",
		"lint": "turbo lint",
		"lint:fix": "turbo lint:fix",
		"ts": "turbo ts",
		"test": "turbo test",
		"docs:generate": "typedoc",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@commitlint/cli": "catalog:",
		"@commitlint/config-conventional": "catalog:",
		"@nivalis/biome-config": "catalog:",
		"lefthook": "catalog:",
		"turbo": "catalog:",
		"typedoc": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
