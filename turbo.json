{
	"$schema": "https://v2-8-12.turborepo.dev/schema.json",
	"globalPassThroughEnv": ["COREPACK_HOME", "ENABLE_EXPERIMENTAL_COREPACK"],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"dependsOn": ["^build"],
			"env": [
				"NEXT_PUBLIC_VERCEL_URL",
				"NEXT_PUBLIC_SENTRY_DSN",
				"NODE_ENV",
				"DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"SENTRY_DSN",
				"SENTRY_AUTH_TOKEN"
			],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"cache": false,
			"dependsOn": ["^lint:fix"]
		},
		"ts": {
			"dependsOn": ["^ts"],
			"outputs": [".next/types/**", "!.next/cache/**", "tsconfig.tsbuildinfo"]
		},
		"test": {
			"cache": false,
			"dependsOn": ["^build"]
		}
	}
}
