{
	"$schema": "https://v2-8-12.turborepo.dev/schema.json",
	"globalDependencies": [".env"],
	"globalPassThroughEnv": [
		"COREPACK_HOME",
		"ENABLE_EXPERIMENTAL_COREPACK",
		"DATABASE_URL",
		"DATABASE_URL_POOLER",
		"BETTER_AUTH_SECRET",
		"OPENAI_API_KEY",
		"MISTRAL_API_KEY",
		"GOOGLE_GENERATIVE_AI_API_KEY",
		"FIRECRAWL_API_KEY",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_CLIENT_SECRET",
		"GOOGLE_REFRESH_TOKEN",
		"SENTRY_DSN",
		"SENTRY_AUTH_TOKEN",
		"NEXT_PUBLIC_SENTRY_DSN",
		"NEXT_PUBLIC_VERCEL_URL"
	],
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"dependsOn": ["^build"],
			"env": [
				"NEXT_PUBLIC_VERCEL_URL",
				"NEXT_PUBLIC_SENTRY_DSN",
				"NODE_ENV",
				"DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"SENTRY_DSN",
				"SENTRY_AUTH_TOKEN",
				"OPENAI_API_KEY",
				"MISTRAL_API_KEY",
				"GOOGLE_GENERATIVE_AI_API_KEY",
				"FIRECRAWL_API_KEY",
				"GOOGLE_CLIENT_ID",
				"GOOGLE_CLIENT_SECRET",
				"GOOGLE_REFRESH_TOKEN"
			],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"lint:fix": {
			"cache": false,
			"dependsOn": ["^lint:fix"]
		},
		"ts": {
			"dependsOn": ["^ts"],
			"outputs": [".next/types/**", "!.next/cache/**", "tsconfig.tsbuildinfo"]
		},
		"test": {
			"cache": false,
			"dependsOn": ["^build"]
		}
	}
}
